@model List<TeamMaker_WebApp.Models.Team>

@{
    ViewData["Title"] = "Generated Teams";
    var activeTeams = Model.Where(t => t.Players.Any()).ToList();
    int totalPlayers = activeTeams.Sum(t => t.Players.Count);
    int totalForwards = activeTeams.Sum(t => t.Players.Count(p => p.Position == "Forward"));
    int totalGoalkeepers = activeTeams.Sum(t => t.Players.Count(p => p.Position == "Goalkeeper"));
    string[] accentColors = { "green", "blue", "amber", "purple", "red" };
}

<link rel="stylesheet" href="~/css/generated-teams.css" />

<div class="gt-page container">

    @if (!activeTeams.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="bi bi-people"></i>
            </div>
            <h2 class="empty-title">No teams generated yet</h2>
            <p class="empty-body">Head to the home page to create balanced teams from your player pool.</p>
            <a href="@Url.Action("Index", "Home")" class="btn-primary-lg">
                <i class="bi bi-arrow-right-circle"></i> Generate teams
            </a>
        </div>
    }
    else
    {
        <div class="gt-header">
            <div>
                <div class="gt-eyebrow">Team generator</div>
                <h1 class="gt-title">Generated teams</h1>
                <p class="gt-subtitle">Last generated · @DateTime.Now.ToString("dddd, MMM d") at @DateTime.Now.ToString("h:mm tt")</p>
            </div>
        </div>

        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-label">Total teams</div>
                <div class="stat-value">@activeTeams.Count</div>
                <div class="stat-sub">from pool of @totalPlayers</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Players assigned</div>
                <div class="stat-value">@totalPlayers</div>
                <div class="stat-sub">@Math.Ceiling((double)totalPlayers / activeTeams.Count) avg per team</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Forwards</div>
                <div class="stat-value">@totalForwards</div>
                <div class="stat-sub">across all teams</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Goalkeepers</div>
                <div class="stat-value">@totalGoalkeepers</div>
                <div class="stat-sub">in squad</div>
            </div>
        </div>

        <div class="toolbar">
            <div class="toolbar-left">
                <button id="shuffleTeamsBtn" class="btn-primary">
                    <i class="bi bi-shuffle"></i> Shuffle teams
                </button>
                <button class="btn-secondary" onclick="window.print()">
                    <i class="bi bi-printer"></i> Print
                </button>
            </div>
            <a asp-controller="Player" asp-action="Index" class="btn-ghost">
                <i class="bi bi-arrow-left"></i> Back to players
            </a>
        </div>

        <div class="drag-hint">
            <i class="bi bi-info-circle"></i>
            Drag players between teams to rebalance. Click <i class="bi bi-x-circle"></i> to remove a player.
        </div>

        <div class="teams-grid" id="teamsContainer">
            @for (int i = 0; i < activeTeams.Count; i++)
            {
                var team = activeTeams[i];
                var accent = accentColors[i % accentColors.Length];
                var badgeClass = $"badge-{accent}";
                var fw = team.Players.Count(p => p.Position == "Forward");
                var md = team.Players.Count(p => p.Position == "Midfielder");
                var df = team.Players.Count(p => p.Position == "Defender");
                var gk = team.Players.Count(p => p.Position == "Goalkeeper");

                <div class="team-card @accent" id="team@(i + 1)Card">
                    <div class="team-header">
                        <span class="team-name">Team @(i + 1)</span>
                        <span class="team-badge @badgeClass">@team.Players.Count players</span>
                    </div>

                    <div class="team-body">
                        @foreach (var player in team.Players)
                        {
                            var posCode = player.Position switch {
                                "Forward"    => "FW",
                                "Midfielder" => "MF",
                                "Defender"   => "DF",
                                "Goalkeeper" => "GK",
                                _            => "--"
                            };
                            var posClass = player.Position switch {
                                "Forward"    => "pos-fw",
                                "Midfielder" => "pos-md",
                                "Defender"   => "pos-df",
                                "Goalkeeper" => "pos-gk",
                                _            => ""
                            };

                            <div class="player-row"
                                 data-player="@player.PlayerName"
                                 data-pos="@posCode"
                                 data-posclass="@posClass"
                                 data-num="@player.Number">
                                <div class="player-left">
                                    <div class="p-num">@player.Number</div>
                                    <span class="p-name">@player.PlayerName</span>
                                </div>
                                <div class="player-right">
                                    <span class="p-pos @posClass">@posCode</span>
                                    <button class="btn-remove-player"
                                            title="Remove from team"
                                            onclick="removePlayer(this)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="team-footer">
                        <span class="tf-stat"><span>@gk</span> GK</span>
                        <span class="tf-stat"><span>@df</span> DF</span>
                        <span class="tf-stat"><span>@md</span> MF</span>
                        <span class="tf-stat"><span>@fw</span> FW</span>
                    </div>
                </div>
            }
        </div>

        <div class="footer-bar">
            <div class="pos-legend">
                <div class="leg-item"><div class="leg-dot pos-gk-dot"></div> Goalkeeper</div>
                <div class="leg-item"><div class="leg-dot pos-df-dot"></div> Defender</div>
                <div class="leg-item"><div class="leg-dot pos-md-dot"></div> Midfielder</div>
                <div class="leg-item"><div class="leg-dot pos-fw-dot"></div> Forward</div>
            </div>
            <span class="footer-note">Drag players between cards to rebalance teams</span>
        </div>
    }
</div>

@section Scripts {
<script>
    let draggedRow = null;

    function initDragDrop() {
        document.querySelectorAll('.player-row').forEach(row => {
            const clone = row.cloneNode(true);
            row.parentNode.replaceChild(clone, row);
        });

        document.querySelectorAll('.player-row').forEach(row => {
            row.setAttribute('draggable', 'true');

            row.addEventListener('dragstart', e => {
                draggedRow = row;
                setTimeout(() => row.classList.add('dragging'), 0);
                e.dataTransfer.effectAllowed = 'move';
            });

            row.addEventListener('dragend', () => {
                document.querySelectorAll('.player-row')
                        .forEach(r => r.classList.remove('dragging'));
                document.querySelectorAll('.team-body')
                        .forEach(b => b.classList.remove('drag-over'));
                draggedRow = null;
                updateAllFooters();
            });
        });

        document.querySelectorAll('.team-body').forEach(body => {

            const freshBody = body.cloneNode(true);
            body.parentNode.replaceChild(freshBody, body);
        });

        document.querySelectorAll('.team-body').forEach(body => {
            body.addEventListener('dragover', e => {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                body.classList.add('drag-over');
            });

            body.addEventListener('dragleave', e => {
                if (!body.contains(e.relatedTarget))
                    body.classList.remove('drag-over');
            });

            body.addEventListener('drop', e => {
                e.preventDefault();
                e.stopPropagation();
                body.classList.remove('drag-over');

                if (!draggedRow) return;
                if (draggedRow.closest('.team-body') === body) return;
                body.appendChild(draggedRow);
                draggedRow = null;

                updateAllFooters();
                initDragDrop(); 
            });
        });

        document.querySelectorAll('.btn-remove-player').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                const row = this.closest('.player-row');
                const name = row.querySelector('.p-name')?.textContent?.trim() || 'this player';
                if (confirm(`Remove ${name} from this team?`)) {
                    row.remove();
                    updateAllFooters();
                }
            });
        });
    }

    function updateAllFooters() {
        document.querySelectorAll('.team-card').forEach(card => {
            const rows = card.querySelectorAll('.player-row');
            let gk = 0, df = 0, md = 0, fw = 0;

            rows.forEach(r => {
                const pos = r.querySelector('.p-pos')?.textContent?.trim();
                if (pos === 'GK') gk++;
                else if (pos === 'DF') df++;
                else if (pos === 'MF') md++;
                else if (pos === 'FW') fw++;
            });

            const footer = card.querySelector('.team-footer');
            if (footer) {
                footer.innerHTML = `
                    <span class="tf-stat"><span>${gk}</span> GK</span>
                    <span class="tf-stat"><span>${df}</span> DF</span>
                    <span class="tf-stat"><span>${md}</span> MF</span>
                    <span class="tf-stat"><span>${fw}</span> FW</span>`;
            }

            const badge = card.querySelector('.team-badge');
            if (badge) badge.textContent = `${rows.length} players`;
        });
    }

    document.getElementById('shuffleTeamsBtn')?.addEventListener('click', function () {
        const teamBodies = document.querySelectorAll('.team-body');
        let allRows = [];

        teamBodies.forEach(body => {
            body.querySelectorAll('.player-row').forEach(r => allRows.push(r));
        });

        // Fisher-Yates shuffle
        for (let i = allRows.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [allRows[i], allRows[j]] = [allRows[j], allRows[i]];
        }

        // Clear all team bodies first
        teamBodies.forEach(body => body.innerHTML = '');

        // Redistribute evenly
        const teamCount = teamBodies.length;
        const perTeam = Math.floor(allRows.length / teamCount);
        let extra = allRows.length % teamCount;
        let idx = 0;

        teamBodies.forEach(body => {
            const take = perTeam + (extra > 0 ? 1 : 0);
            if (extra > 0) extra--;
            for (let i = 0; i < take && idx < allRows.length; i++, idx++) {
                body.appendChild(allRows[idx]);
            }
        });

        initDragDrop();
        updateAllFooters();
    });

    // Boot on page load
    initDragDrop();
</script>
}
