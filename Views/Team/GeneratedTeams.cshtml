@model List<TeamMaker_WebApp.Models.Team>

@{
    ViewData["Title"] = "Generated Teams";

    var activeTeams = Model.Where(t => t.Players.Any()).ToList();

    int totalPlayers = activeTeams.Sum(t => t.Players.Count);

    var teamNames = new[]
    {
        "Blue Team",
        "Green Team",
        "Red Team",
        "Yellow Team"
    };

    var teamColors = new[]
    {
        "blue",
        "green",
        "red",
        "yellow"
    };
}

<link rel="stylesheet" href="~/css/generated-teams.css" />

<div class="container generated-page py-4">

    <div class="print-header">
    <h1>TeamMaker</h1>
    <p>Team Rosters — @DateTime.Now.ToString("MMMM d, yyyy")</p>
</div>

    @if (!activeTeams.Any())
    {
        <div class="text-center mt-5">
            <i class="bi bi-people display-1 text-secondary"></i>
            <h2 class="mt-3">No Teams Generated</h2>
            <p class="text-muted">Generate teams from the Home page.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                Generate Teams
            </a>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="fw-bold">Generated Teams</h1>
                <h2 class="text-muted mb-0">
                    Drag players between teams. Changes save automatically.
                </h2>
            </div>
            <div>
                <button id="shuffleTeamsBtn" class="btn btn-primary">
                    <i class="bi bi-shuffle"></i> Shuffle
                </button>
                <button onclick="window.print()" class="btn btn-outline-dark ms-2">
                    <i class="bi bi-printer"></i> Print
                </button>
            </div>
        </div>

        <!-- Stats -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h3 id="totalPlayers">@totalPlayers</h3>
                        <small>Total Players</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h3>@activeTeams.Count</h3>
                        <small>Total Teams</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h3>@(Math.Ceiling((double)totalPlayers / activeTeams.Count))</h3>
                        <small>Average Players</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Teams -->
        <div class="row">
            @for (int i = 0; i < activeTeams.Count; i++)
            {
                var team = activeTeams[i];

                var teamName = i < teamNames.Length
                    ? teamNames[i]
                    : $"Team {i + 1}";

                var color = i < teamColors.Length
                    ? teamColors[i]
                    : "blue";

                <div class="col-lg-6 mb-4">
                    <div class="team-card">
                        <div class="team-header team-@color">
                            <h4>@teamName</h4>
                            <span class="badge bg-light text-dark team-count">
                                @team.Players.Count Players
                            </span>
                        </div>

                        <div class="team-body drop-zone" data-team-id="@team.TeamId">
                            @foreach (var player in team.Players)
                            {
                                var badge = player.Position switch
                                {
                                    "Forward" => "bg-warning",
                                    "Midfielder" => "bg-primary",
                                    "Defender" => "bg-success",
                                    "Goalkeeper" => "bg-danger",
                                    _ => "bg-secondary"
                                };

                                <div class="player-row" draggable="true" data-player-id="@player.PlayerId">
                                    <div class="player-info">
                                        <img src="@(string.IsNullOrEmpty(player.ImagePath)
                                                ? Url.Content("~/Images/Players/default.webp")
                                                : Url.Content(player.ImagePath))"
                                             class="player-photo">
                                        <div>
                                            <strong>@player.PlayerName</strong>
                                            <br>
                                            <small>Jersey #@player.Number</small>
                                        </div>
                                    </div>

                                    <span class="badge @badge">@player.Position</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

<div id="toast" class="toast-message"></div>

<script>

    let draggedPlayer = null;

    document.querySelectorAll(".player-row").forEach(item => {
        item.addEventListener("dragstart", function () {
            draggedPlayer = this;
            this.classList.add("dragging");
        });

        item.addEventListener("dragend", function () {
            this.classList.remove("dragging");
        });
    });

    document.querySelectorAll(".drop-zone").forEach(zone => {
        zone.addEventListener("dragover", function (e) {
            e.preventDefault();
        });

        zone.addEventListener("drop", function (e) {
            e.preventDefault();
            if (draggedPlayer) {
                this.appendChild(draggedPlayer);
            }
        });
    });


document.getElementById("shuffleTeamsBtn")?.addEventListener("click", function () {
    shuffleTeams();
});

function shuffleTeams() {
    const dropZones = Array.from(document.querySelectorAll(".drop-zone"));
    if (dropZones.length === 0) return;


    const allPlayers = [];
    dropZones.forEach(zone => {
        Array.from(zone.children).forEach(row => allPlayers.push(row));
    });


    for (let i = allPlayers.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [allPlayers[i], allPlayers[j]] = [allPlayers[j], allPlayers[i]];
    }

    dropZones.forEach(zone => {
        zone.innerHTML = "";
    });

  
    allPlayers.forEach((row, index) => {
        const zone = dropZones[index % dropZones.length];
        zone.appendChild(row);
    });

    document.querySelectorAll(".player-row").forEach(item => {
        item.addEventListener("dragstart", function () {
            draggedPlayer = this;
            this.classList.add("dragging");
        });
        item.addEventListener("dragend", function () {
            this.classList.remove("dragging");
        });
    });

 
    dropZones.forEach(zone => {
        const count = zone.children.length;
        const badge = zone.closest(".team-card")?.querySelector(".team-count");
        if (badge) badge.textContent = `${count} Players`;
    });
}
</script>