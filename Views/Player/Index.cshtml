@model List<TeamMaker_WebApp.Models.Player>

@{
    ViewData["Title"] = "Player List";
}

<link rel="stylesheet" href="~/css/player-list.css" />

<div class="tm-page">
    <div class="tm-header">
        <div class="tm-title-group">
            <div class="tm-eyebrow">Squad management</div>
            <h1 class="tm-title">
                Player List
                <span class="tm-count-badge">
                    <i class="bi bi-people-fill"></i> @Model.Count
                </span>
            </h1>
        </div>
        <div class="tm-header-actions">
            <button type="button"
                    class="tm-clear-btn"
                    onclick="openClearAllModal()"
                    @(Model.Count == 0 ? "disabled" : "")>
                <i class="bi bi-trash3"></i> Clear all players
            </button>
            <a asp-action="Create" class="tm-add-btn">
                <i class="bi bi-plus-lg"></i> Add new player
            </a>
        </div>
    </div>

    <form id="clearAllForm" asp-controller="Player" asp-action="ClearAll" method="post" style="display:none;"></form>

    <div id="clearAllOverlay" class="tm-modal-overlay">
        <div class="tm-modal">
            <div class="tm-modal-icon">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <h3 class="tm-modal-title">Delete all players?</h3>
            <p class="tm-modal-body">
                This will permanently remove all <strong>@Model.Count</strong> players
                from the database. This action cannot be undone.
            </p>
            <div class="tm-modal-actions">
                <button type="button" class="tm-modal-cancel" onclick="closeClearAllModal()">
                    Cancel
                </button>
                <button type="button" class="tm-modal-confirm" onclick="confirmClearAll()">
                    <i class="bi bi-trash3"></i> Yes, delete all
                </button>
            </div>
        </div>
    </div>

    @{
    var current = ViewBag.CurrentPosition as string ?? "All";
}

<div class="tm-filters">
    <a href="@Url.Action("Index")"
       class="tm-filter-btn @(current == "All" ? "active" : "")">All</a>

    <a href="@Url.Action("Index", new { position = "Forward" })"
       class="tm-filter-btn @(current == "Forward" ? "active" : "")">Forwards</a>

    <a href="@Url.Action("Index", new { position = "Midfielder" })"
       class="tm-filter-btn @(current == "Midfielder" ? "active" : "")">Midfielders</a>

    <a href="@Url.Action("Index", new { position = "Defender" })"
       class="tm-filter-btn @(current == "Defender" ? "active" : "")">Defenders</a>

    <a href="@Url.Action("Index", new { position = "Goalkeeper" })"
       class="tm-filter-btn @(current == "Goalkeeper" ? "active" : "")">Goalkeepers</a>
</div>

    <div class="tm-table-wrap">
        <table class="tm-table">
            <thead>
                <tr>
                    <th>Player</th>
                    <th>Position</th>
                    <th>No.</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var player in Model)
                {
                    var nameParts = (player.PlayerName ?? "")
    .Split(' ', StringSplitOptions.RemoveEmptyEntries);

var initials = nameParts.Length > 0
    ? string.Concat(nameParts.Take(2).Select(w => w[0])).ToUpper()
    : "?";
                    var posClass = player.Position?.ToLower() switch {
                        "forward"    => "pos-forward",
                        "midfielder" => "pos-midfielder",
                        "defender"   => "pos-defender",
                        "goalkeeper" => "pos-goalkeeper",
                        _ => "pos-default"
                    };
                  var isSpecialNum = player.Number is 10 or 11 ;

                    <tr>
                        <td>
                           <div class="player-cell">
                                <img src="@(string.IsNullOrEmpty(player.ImagePath) ? "/Images/Players/default.webp" : player.ImagePath)"
                                     class="player-thumb" alt="@player.PlayerName" />
                                <span class="player-name">@player.PlayerName</span>
                            </div>

                 </td>
                        <td>
                            <span class="pos-badge @posClass">@player.Position</span>
                        </td>
                        <td>
                         <span class="num-badge @(isSpecialNum ? "special" : "")">
                                @player.Number
                            </span>
                        </td>
                        <td class="action-cell">
                            <a asp-controller="Player" asp-action="Edit"
                               asp-route-id="@player.PlayerId" class="btn-action btn-edit">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-controller="Player" asp-action="Details"
                               asp-route-id="@player.PlayerId" class="btn-action btn-details">
                                Details
                            </a>
                            <a asp-controller="Player" asp-action="Delete"
                               asp-route-id="@player.PlayerId" class="btn-action btn-delete">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="tm-footer">
        <span class="tm-count">Showing @Model.Count players</span>
    </div>

    <div class="generator-cta">

    <div class="generator-cta-content">

        <div>
            <span class="cta-badge">
                ⚽ Team Generator
            </span>

            <h2>
                Ready to Create Balanced Teams?
            </h2>

            <p>
                Select players, choose the number of teams, and let TeamMaker
                generate fair and balanced squads instantly.
            </p>
        </div>

        <a asp-controller="Home"
           asp-action="Index"
           asp-fragment="team-generator"
           class="btn-generator">

            <i class="bi bi-shuffle"></i>

            Generate Teams

        </a>

    </div>

</div>
<script>
    function openClearAllModal() {
        document.getElementById("clearAllOverlay").classList.add("show");
    }

    function closeClearAllModal() {
        document.getElementById("clearAllOverlay").classList.remove("show");
    }

    function confirmClearAll() {
        document.getElementById("clearAllForm").submit();
    }

    document.getElementById("clearAllOverlay").addEventListener("click", function (e) {
        if (e.target === this) closeClearAllModal();
    });
</script>
    
</div>
