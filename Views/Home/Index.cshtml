@model List<TeamMaker_WebApp.Models.Player>

@{
    ViewData["Title"] = "TeamMaker";
}

<link rel="stylesheet" href="~/css/home.css" />

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error">
        <i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]
    </div>
}

<!-- Hero Slideshow -->
<div class="slideshow-wrapper">
    <div class="slideshow-container">
        <div class="slide active">
            <img src="~/Images/Portfolio/IMG1.webp" class="carousel-img" alt="Banner " />
        </div>
        <div class="slide">
            <img src="~/Images/Portfolio/IMG3.webp" class="carousel-img" alt="Banner " />
        </div>
        <div class="slide">
            <img src="~/Images/Portfolio/IMG4.webp" class="carousel-img" alt="Banner " />
        </div>
    </div>
    <div class="slide-overlay">
        <div class="slide-text">
            <div class="slide-eyebrow">Official Platform</div>
            <h1 class="slide-title">Create Your Teams Instantly</h1>
            <p class="slide-subtitle">Select your squad and generate balanced teams instantly</p>
        </div>
    </div>
    <div class="slide-dots" id="slideDots"></div>
</div>
<section class="steps-section">

    <div class="section-header text-center">

        <h2 class="section-title">
            How It Works
        </h2>

    </div>

    <div class="steps-grid">

        <div class="step">
            <span>1</span>
            <h4>Add Players</h4>
            <p>Create your football squad.</p>
        </div>

        <div class="step">
            <span>2</span>
            <h4>Select Players</h4>
            <p>Choose the players for today's match.</p>
        </div>

        <div class="step">
            <span>3</span>
            <h4>Choose Teams</h4>
            <p>Select whether to create 2, 3 or 4 teams.</p>
        </div>

        <div class="step">
            <span>4</span>
            <h4>Generate</h4>
            <p>Instantly receive balanced football teams.</p>
        </div>

    </div>

</section>

<section class="cta-section">

<h2>

Ready to Create Balanced Football Teams?

</h2>

<p>

Manage players and generate teams in seconds.

</p>

<a asp-controller="Player"
   asp-action="Index"
   class="btn btn-primary btn-lg">

Add Your Players

</a>

</section>


<!-- Main Form -->
<div class="home-container"  id="team-generator">

    <form asp-controller="Home" asp-action="GenerateTeams" method="post" id="teamForm">

        <!-- Section Header -->
        <div class="section-header">
            <div>
                <div class="section-eyebrow">Team generator</div>
                <h2 class="section-title">Build your teams</h2>
                <p class="section-sub">Select players from the squad, choose how many teams, then generate.</p>
            </div>
        </div>

        <!-- Config Row -->
        <div class="config-row">
            <div class="config-card">
                <div class="config-label">Number of teams</div>
                <div class="team-count-btns">
                    <input type="hidden" name="teamCount" id="teamCountInput" value="2" />
                    <button type="button" class="count-btn active" onclick="setTeamCount(2, this)">2</button>
                    <button type="button" class="count-btn" onclick="setTeamCount(3, this)">3</button>
                    <button type="button" class="count-btn" onclick="setTeamCount(4, this)">4</button>
                </div>
            </div>

            <div class="config-card">
                <div class="config-label">Players selected</div>
                <div class="config-value">
                    <span id="selectedCount">0</span>
                    <span class="config-total">/ @Model.Count</span>
                </div>
            </div>

            <div class="config-card">
                <div class="config-label">Avg per team</div>
                <div class="config-value">
                    <span id="avgPerTeam">0</span>
                </div>
            </div>

            <div class="config-actions">
                <button type="button" class="btn-select-all" onclick="selectAll()">
                    <i class="bi bi-check-all"></i> Select all
                </button>
                <button type="button" class="btn-clear-all" onclick="clearAll()">
                    <i class="bi bi-x"></i> Clear
                </button>
            </div>
        </div>

        <!-- Player Grid -->
        <div class="player-grid" id="playerGrid">
            @foreach (var player in Model)
            {
                var posCode = player.Position switch {
                    "Forward"    => "FW",
                    "Midfielder" => "MF",
                    "Defender"   => "DF",
                    "Goalkeeper" => "GK",
                    _            => "--"
                };
                var posClass = player.Position switch {
                    "Forward"    => "pos-fw",
                    "Midfielder" => "pos-md",
                    "Defender"   => "pos-df",
                    "Goalkeeper" => "pos-gk",
                    _            => ""
                };
              var nameParts = (player.PlayerName ?? "")
    .Split(' ', StringSplitOptions.RemoveEmptyEntries);

var initials = nameParts.Length > 0
    ? string.Concat(nameParts.Take(2).Select(w => w[0])).ToUpper()
    : "?";;

                <div class="player-card" onclick="togglePlayer(this)"
                     data-player-id="@player.PlayerId">
                    <div class="player-card-top">
                        <div class="player-initials">@initials</div>
                        <div class="player-num-big">#@player.Number</div>
                        <div class="selected-check">
                            <i class="bi bi-check-lg"></i>
                        </div>
                    </div>
                    <div class="player-card-body">
                        <div class="player-card-name">@player.PlayerName</div>
                        <span class="p-pos-badge @posClass">@posCode</span>
                    </div>
                </div>
            }
        </div>

        <!-- Hidden inputs container -->
        <div id="selectedPlayersInputs"></div>

        <!-- Generate Button -->
        <div class="generate-bar">
            <div class="generate-bar-left">
                <span id="generateHint" class="generate-hint">Select players above to get started</span>
            </div>
            <button type="submit" class="btn-generate" id="generateBtn" disabled>
                <i class="bi bi-shuffle"></i> Generate teams
            </button>
        </div>

    </form>
</div>

@section Scripts {
<script>
    // ── Slideshow ─────────────────────────────
    const slides = document.querySelectorAll('.slide');
    const dotsContainer = document.getElementById('slideDots');
    let currentSlide = 0;
    let slideInterval;

    slides.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.className = 'slide-dot' + (i === 0 ? ' active' : '');
        dot.setAttribute('aria-label', `Slide ${i + 1}`);
        dot.addEventListener('click', () => goToSlide(i));
        dotsContainer.appendChild(dot);
    });

    function goToSlide(index) {
        slides[currentSlide].classList.remove('active');
        dotsContainer.children[currentSlide].classList.remove('active');
        currentSlide = index;
        slides[currentSlide].classList.add('active');
        dotsContainer.children[currentSlide].classList.add('active');
        clearInterval(slideInterval);
        slideInterval = setInterval(nextSlide, 4000);
    }

    function nextSlide() {
        goToSlide((currentSlide + 1) % slides.length);
    }

    slideInterval = setInterval(nextSlide, 4000);

    // ── Player selection ──────────────────────
    let selectedIds = new Set();
    let teamCount = 2;

    function togglePlayer(card) {
        const id = card.dataset.playerId;
        if (selectedIds.has(id)) {
            selectedIds.delete(id);
            card.classList.remove('selected');
        } else {
            selectedIds.add(id);
            card.classList.add('selected');
        }
        syncInputs();
        updateStats();
    }

    function selectAll() {
        document.querySelectorAll('.player-card').forEach(card => {
            card.classList.add('selected');
            selectedIds.add(card.dataset.playerId);
        });
        syncInputs();
        updateStats();
    }

    function clearAll() {
        document.querySelectorAll('.player-card').forEach(card => {
            card.classList.remove('selected');
        });
        selectedIds.clear();
        syncInputs();
        updateStats();
    }

    function setTeamCount(count, btn) {
        teamCount = count;
        document.getElementById('teamCountInput').value = count;
        document.querySelectorAll('.count-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        updateStats();
    }

    function syncInputs() {
        const container = document.getElementById('selectedPlayersInputs');
        container.innerHTML = '';
        selectedIds.forEach(id => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'selectedPlayerIds';
            input.value = id;
            container.appendChild(input);
        });
    }

    function updateStats() {
        const count = selectedIds.size;
        document.getElementById('selectedCount').textContent = count;

        const avg = count > 0 ? Math.floor(count / teamCount) : 0;
        document.getElementById('avgPerTeam').textContent = avg;

        const btn = document.getElementById('generateBtn');
        const hint = document.getElementById('generateHint');

        if (count === 0) {
            hint.textContent = 'Select players above to get started';
            btn.disabled = true;
        } else if (count < teamCount) {
            hint.textContent = `Need at least ${teamCount} players for ${teamCount} teams`;
            btn.disabled = true;
        } else {
            hint.textContent = `${count} players → ${teamCount} teams of ~${avg}`;
            btn.disabled = false;
        }
    }

    // ── Form validation ───────────────────────
    document.getElementById('teamForm').addEventListener('submit', function (e) {
        if (selectedIds.size === 0) {
            alert('Please select at least one player.');
            e.preventDefault();
            return;
        }
        if (selectedIds.size < teamCount) {
            alert(`Select at least ${teamCount} players to make ${teamCount} teams.`);
            e.preventDefault();
        }
    });
</script>


<section class="feature-section">

    <div class="section-header text-center">
        <div class="section-eyebrow">
            FEATURES
        </div>

        <h2 class="section-title">
            Why Choose TeamMaker?
        </h2>

        <p class="section-sub">
            Everything you need to organize football matches quickly.
        </p>
    </div>

    <div class="feature-grid">

        <div class="feature-card">
            <i class="bi bi-person-plus-fill"></i>
            <h4>Player Management</h4>
            <p>Add, edit and organize players with profile images.</p>
        </div>

        <div class="feature-card">
            <i class="bi bi-shuffle"></i>
            <h4>Random Team Generator</h4>
            <p>Create balanced football teams with one click.</p>
        </div>

        <div class="feature-card">
            <i class="bi bi-images"></i>
            <h4>Player Images</h4>
            <p>Every player can have their own profile photo.</p>
        </div>

        <div class="feature-card">
            <i class="bi bi-printer-fill"></i>
            <h4>Printable Teams</h4>
            <p>View and print generated teams anytime.</p>
        </div>

    </div>

</section>




<section class="gallery-section">

    <div class="section-header text-center">

        <h2 class="section-title">
            Gallery
        </h2>

        <p class="section-sub">
            Moments from the football field.
        </p>

    </div>

    <div class="gallery-grid">

        <img src="~/Images/Portfolio/IMG1.webp">

        <img src="~/Images/Portfolio/IMG3.webp">

        <img src="~/Images/Portfolio/IMG4.webp">

        <img src="~/Images/Portfolio/IMG2.webp">

    </div>

</section>

<section class="faq-section">

<h2 class="section-title text-center">

Frequently Asked Questions

</h2>

<div class="faq">

<h4>How are teams generated?</h4>

<p>
Players are randomly distributed as evenly as possible.
</p>

</div>

<div class="faq">

<h4>Can I upload player images?</h4>

<p>

Yes. Every player can have their own profile picture.

</p>

</div>

<div class="faq">

<h4>Can I edit generated teams?</h4>

<p>

Yes. Players can be managed at any time.

</p>

</div>

</section>
}